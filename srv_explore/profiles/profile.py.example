"""ОБРАЗЕЦ профиля srv-explore. Скан грузит *.py — этот .py.example НЕ подхватывается.
Скопируй в <id>.py, поправь ID/COMMANDS/DESC и check.

Профиль описывает одно семейство команд и что в нём — только чтение.
Не подключён/выключен → все его COMMANDS блокируются. Подключён → решает check.

Контракт:
    ID:       str          — уникальный id, ключ тумблера в админке
    COMMANDS: list[str]    — бинарники профиля
    DESC:     str          — одна строка для админки
    def check(argv, g) -> (ok: bool, reason: str)

g — универсальные примитивы ядра (class Toolkit, guard.py):
    g.verbs(argv, allow, subreads, value_flags, deny_flags,
            allow_flags, require_flag, allow_bare, no_follow)  # verb+flag движок
    g.subcommand(argv, value_flags)   # первый позиционный + хвост
    g.values(argv, flags, file_flags) # значения флагов; file_flag → ошибка
    g.forbid_words(text, words)       # \bword\b, вернёт совпавшее
    g.forbid_substr(text, subs)       # подстрока
    g.follows(argv)                   # -f / --follow
    g.url_host(url), g.internal_host(host)
    g.recurse(argv)                   # вложенную команду через весь гард
    g.name(argv)
"""

ID = "myredis"
COMMANDS = ["myredis-cli"]
DESC = "myredis-cli (пример: только read-глаголы)"


def check(argv, g):
    return g.verbs(
        argv,
        value_flags=["-h", "-p", "-a"],
        deny_flags=["--eval", "--pipe"],
        allow=["GET", "MGET", "INFO", "PING"],
        subreads={"CONFIG": ["GET"]},
    )


