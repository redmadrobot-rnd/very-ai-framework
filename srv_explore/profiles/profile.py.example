"""ОБРАЗЕЦ профиля srv-explore. Скан грузит *.py — этот .py.example НЕ подхватывается.
Скопируй в <id>.py и поправь.

Профиль = ТОНКИЙ КОНФИГ подготовки инструмента, НЕ парсер команд. read-only держит
ресурс-слой (read-only роль СУБД / socket-proxy / firewall / RO-FS), не гард.
По этому конфигу провизионер ставит клиент, создаёт read-only доступ и проверяет его.

Поля:
    ID:        str          — уникальный id, ключ тумблера в админке
    DESC:      str          — одна строка для админки
    COMMANDS:  list[str]    — что инструмент даёт (информативно)
    PACKAGES:  list[str]    — apt-пакеты клиента (ставит провизионер)
    CREDS_ENV: str          — имя Secret с read-only коннекшеном для агента
    SETUP:     str | None   — рецепт read-only доступа (:role/:db/:pw подставит провизионер)
    VERIFY:    str | None   — проба барьера: должна упасть «permission denied»
"""

ID = "mydb"
DESC = "MyDB — read-only роль"
COMMANDS = ["mydb-cli"]
PACKAGES = ["mydb-client"]
CREDS_ENV = "MYDB_INSPECTOR_DSN"
SETUP = "CREATE USER :role READ ONLY PASSWORD ':pw'"
VERIFY = "CREATE TABLE _srvx_probe (x int)"
