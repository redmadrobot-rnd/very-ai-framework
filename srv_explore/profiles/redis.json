{
  "name": "redis",
  "kind": "redis",
  "client": "redis-cli",
  "note": "Read-only: команда = первый позиционный токен после флагов подключения. Настоящая граница = ACL-юзер +@read -@dangerous в самом Redis. Парсер пускает только read-глаголы; контейнерные команды (CONFIG/CLIENT/…) — только их read-подкоманды. --eval (Lua), -x (stdin-arg), --pipe, интерактив без команды — запрещены.",
  "readonly_recipe": [
    "ACL SETUSER inspector on >PASSWORD ~* &* +@read -@dangerous resetchannels",
    "# +@read = только читающие команды; -@dangerous убирает FLUSHALL/KEYS*/CONFIG SET/DEBUG/SHUTDOWN",
    "# проверить: ACL GETUSER inspector ; НЕ давать +@write/+@admin/+@scripting/allcommands"
  ],
  "secret_env": "REDIS_INSPECTOR_PASSWORD",
  "value_flags": ["-h", "-p", "-a", "-n", "-u", "-t", "--user", "--pass", "--timeout", "--cacert", "--cert", "--key"],
  "allow_commands": [
    "GET", "MGET", "STRLEN", "GETRANGE", "SUBSTR",
    "EXISTS", "TYPE", "TTL", "PTTL", "EXPIRETIME", "PEXPIRETIME", "DUMP", "TOUCH",
    "SCAN", "RANDOMKEY", "DBSIZE", "KEYS",
    "HGET", "HMGET", "HGETALL", "HKEYS", "HVALS", "HLEN", "HEXISTS", "HSCAN", "HSTRLEN", "HRANDFIELD",
    "LRANGE", "LLEN", "LINDEX", "LPOS",
    "SMEMBERS", "SISMEMBER", "SMISMEMBER", "SCARD", "SSCAN", "SRANDMEMBER", "SINTERCARD",
    "ZRANGE", "ZRANGEBYSCORE", "ZRANGEBYLEX", "ZREVRANGE", "ZREVRANGEBYSCORE", "ZREVRANGEBYLEX",
    "ZCARD", "ZCOUNT", "ZSCORE", "ZMSCORE", "ZRANK", "ZREVRANK", "ZSCAN", "ZLEXCOUNT", "ZRANDMEMBER",
    "XRANGE", "XREVRANGE", "XLEN", "XPENDING",
    "GETBIT", "BITCOUNT", "BITPOS",
    "GEOPOS", "GEODIST", "GEOSEARCH", "GEOHASH",
    "PFCOUNT",
    "INFO", "TIME", "LASTSAVE", "PING", "ECHO", "LOLWUT", "DBSIZE", "WAIT",
    "SINTER", "SUNION", "SDIFF"
  ],
  "subcommand_reads": {
    "CONFIG": ["GET"],
    "CLIENT": ["LIST", "INFO", "ID", "GETNAME", "NO-EVICT", "NO-TOUCH"],
    "MEMORY": ["USAGE", "STATS", "DOCTOR", "MALLOC-STATS"],
    "ACL": ["LIST", "GETUSER", "CAT", "WHOAMI", "USERS"],
    "CLUSTER": ["INFO", "NODES", "SLOTS", "SHARDS", "LINKS", "MYID", "COUNTKEYSINSLOT", "GETKEYSINSLOT", "KEYSLOT"],
    "LATENCY": ["HISTORY", "LATEST", "DOCTOR", "GRAPH"],
    "SLOWLOG": ["GET", "LEN"],
    "COMMAND": ["COUNT", "DOCS", "INFO", "GETKEYS", "LIST"],
    "XINFO": ["STREAM", "GROUPS", "CONSUMERS"],
    "OBJECT": ["ENCODING", "REFCOUNT", "IDLETIME", "FREQ", "HELP"]
  }
}
